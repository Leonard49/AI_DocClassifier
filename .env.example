# Feishu app credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Wiki space
SPACE_ID=

# Source folder to scan (set one of these)
SCAN_ROOT_TOKEN=
# SCAN_FOLDER_NAME=

# Destination folder for classified copies (set one of these)
TARGET_PARENT_TOKEN=
# TARGET_ROOT_NAME=
# FALLBACK_PARENT_TOKEN=

# LLM (OpenAI-compatible gateway; change model here only)
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://qlitellm.phicotek.com/v1
# Legacy alias: QWEN_API_KEY is still read if LLM_API_KEY is empty

# Multi-worker parallel (place SHARED_STATE_DB on a path all workers can access)
# WORKER_ID=alice
# ENABLE_SHARED_DEDUP=true
# SHARED_STATE_DB=F:\shared_db\shared_copy_state.db
# SHARED_STATE_DB=\\HOSTNAME\shared_db\shared_copy_state.db
# CLAIM_TIMEOUT_MINUTES=30

# Optional tuning
# USE_CACHE=false
# MAX_DOCUMENTS=0
# ENABLE_TAG_ADD=true
# SAVE_PROGRESS=true
# FORCE_RESCAN=false
# ENABLE_SCAN_SNAPSHOT=true
# SCAN_SNAPSHOT_DB=scan_snapshot.db
# FULL_SCAN_CALIBRATION_DAYS=7
# SAVE_RUN_LOG=true
# LOG_DIR=logs
# READ_WORKERS=2
# CLASSIFY_WORKERS=4
# CLASSIFY_MAX_CHARS=3000
# USE_CLASSIFY_CACHE=true
# CLASSIFY_VERBOSE=false
# LLM_MAX_RETRIES=6
# LLM_REQUEST_TIMEOUT=120
# PROGRESS_INTERVAL=10
